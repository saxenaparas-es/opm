# Boiler Efficiency API & B - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the values as needed.
# ==============================================================================

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_META=http://your-api-server.com/exactapi
API_QUERY=http://your-api-server.com/kairosapi/api/v1/datapoints/query
API_DATA=http://your-api-server.com/kairosapi/api/v1/datapoints
EFFICIENCY_URL=http://your-api-server.com/efficiency
MODEL_URL=http://your-api-server.com/model/
PREDICTION_URL=http://your-api-server.com/prediction
BATCH_EFFICIENCY_URL=http://your-api-server.com/batchefficiency
SERVICE_URL=http://your-api-server.com/service

# ==============================================================================
# MQTT BROKER CONFIGURATION
# ==============================================================================
BROKER_ADDRESS=192.168.68.170
Q_PORT=1883
BROKER_USERNAME=
BROKER_PASSWORD=

# ==============================================================================
# KAIROSDB CONFIGURATION
# ==============================================================================
KAIROS_URL=http://your-kairos-server.com:8080/api/datapoints
KAIROS_USERNAME=es-user
KAIROS_PASSWORD=your_password

# ==============================================================================
# UNIT CONFIGURATION (REQUIRED)
# ==============================================================================
UNIT_ID=unit_001

# ==============================================================================
# RUN MODE CONFIGURATION
# ==============================================================================
# CRON_MODE: Set to 'true' for single run, 'false' for continuous scheduler
CRON_MODE=false

# FREQUENCY: Interval in seconds between runs in server mode (default: 300 = 5 min)
FREQUENCY=300