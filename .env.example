# Boiler Efficiency API & B - Environment Configuration Template
# ==============================================================================
# this .env is for both combined api & b repository. You can copy this file to .env and fill in the values as needed.

# ==============================================================================
# API CONFIGURATION (Used by BOTH optimized-api & optimized-filter) 
# ==============================================================================
API_META=http://your-api-server.com/metadata
API_QUERY=http://your-api-server.com/query
API_DATA=http://your-api-server.com/datapoints
EFFICIENCY_URL=http://your-api-server.com/efficiency

# ==============================================================================
# MQTT BROKER CONFIGURATION (Used by BOTH optimized-api & optimized-filter)
# ==============================================================================
BROKER_ADDRESS=your-mqtt-broker.com
Q_PORT=1883
BROKER_USERNAME=your_mqtt_username
BROKER_PASSWORD=your_mqtt_password

# ==============================================================================
# API AUTHENTICATION (Optional - Used by BOTH)
# ==============================================================================
API_USERNAME=your_api_username
API_PASSWORD=your_api_password

# ==============================================================================
# UNIT CONFIGURATION (optimized-filter ONLY - REQUIRED)
# ==============================================================================
UNIT_ID=unit_001

# ==============================================================================
# RUN MODE CONFIGURATION (optimized-filter ONLY)
# ==============================================================================
# CRON_MODE: Set to 'true' for single run, 'false' for continuous scheduler
CRON_MODE=false

# FREQUENCY: Interval in seconds between runs in server mode (default: 300 = 5 min)
FREQUENCY=300