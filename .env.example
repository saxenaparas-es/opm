# Boiler Efficiency API & B - Environment Configuration Template
# ==============================================================================
# This .env is for both optimized-api & optimized-filter repositories.
# Copy this file to .env and fill in the values as needed.
# ==============================================================================

# ==============================================================================
# API CONFIGURATION (Used by BOTH optimized-api & optimized-filter)
# ==============================================================================
# Core API endpoints
API_META=http://your-api-server.com/exactapi
API_QUERY=http://your-api-server.com/kairosapi/api/v1/datapoints/query
API_DATA=http://your-api-server.com/kairosapi/api/v1/datapoints
EFFICIENCY_URL=http://your-api-server.com/efficiency

# Additional API endpoints (from app_config)
MODEL_URL=http://your-api-server.com/model/
PREDICTION_URL=http://your-api-server.com/prediction
BATCH_EFFICIENCY_URL=http://your-api-server.com/batchefficiency
SERVICE_URL=http://your-api-server.com/service
FCM_URL=https://fcm.googleapis.com/fcm/send

# ==============================================================================
# MQTT BROKER CONFIGURATION (Used by BOTH optimized-api & optimized-filter)
# ==============================================================================
BROKER_ADDRESS=192.168.68.170
Q_PORT=1883
BROKER_USERNAME=your_mqtt_username
BROKER_PASSWORD=your_mqtt_password

# ==============================================================================
# KAIROSDB CONFIGURATION (Used by optimized-filter for direct HTTP publishing)
# ==============================================================================
KAIROS_URL=http://your-kairos-server.com:8080/api/datapoints

# ==============================================================================
# API AUTHENTICATION (Optional - Used by BOTH)
# ==============================================================================
API_USERNAME=your_api_username
API_PASSWORD=your_api_password

# ==============================================================================
# UNIT CONFIGURATION (optimized-filter ONLY - REQUIRED)
# ==============================================================================
UNIT_ID=unit_001

# ==============================================================================
# RUN MODE CONFIGURATION (optimized-filter ONLY)
# ==============================================================================
# CRON_MODE: Set to 'true' for single run, 'false' for continuous scheduler
CRON_MODE=false

# FREQUENCY: Interval in seconds between runs in server mode (default: 300 = 5 min)
FREQUENCY=300

# ==============================================================================
# APP_CONFIG INTEGRATION (OPTIONAL - For production use)
# ==============================================================================
# If app_config package is installed, it will override these settings.
# To install: cd exsp-packages && ./exec.sh
# Or: pip install -e exsp-packages/app_config
#
# If NOT using app_config, these env variables are sufficient.

# ==============================================================================
# ALTERNATIVE: DIRECT CONFIG (optional override)
# ==============================================================================
# If API_ES env is set, app_config will use it as base URL
# API_ES=api-es